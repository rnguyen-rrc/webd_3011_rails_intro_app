<div class="container mt-4">
  <h1>Ingredients</h1>

  <div class="d-flex justify-content-center my-3">
    <%= paginate @ingredients %>
  </div>

  <table class="table align-middle">
    <thead>
      <tr>
        <th>Name</th>
        <th>Recipes</th>
        <th></th>
      </tr>
    </thead>

    <tbody>
      <% @ingredients.each do |ingredient| %>
        <tr>
          <td><%= ingredient.name %></td>

          <td><%= ingredient.recipes.count %></td>

          <td>
            <%= link_to "Show Recipes", ingredient_path(ingredient), class: "btn btn-outline-success" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <div class="d-flex justify-content-center my-3">
    <%= paginate @ingredients %>
  </div>
</div>