<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Rails Intro App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <%= javascript_importmap_tags %>

    <style>
      body {
        margin: 0;
        font-family: "Segoe UI", Arial, sans-serif;
      }

      /* NAVBAR */
      .navbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background-color: black;
        padding: 10px 20px;
      }

      .brand {
        color: white;
        font-size: 22px;
        margin-right: 30px;
        text-decoration: none;
      }

      .brand:hover {
        color: #ddd;
      }

      .nav-left {
        display: flex;
        align-items: center;
      }

      .nav-links a {
        color: #a8a8a8;
        margin-right: 15px;
        text-decoration: none;
        font-size: 16px;
      }

      .nav-links a:hover {
        color: #d8d8d8;
      }

      .nav-links a.active {
        color: white;
        font-weight: 500;
      }

      /* SEARCH */
      .search-form {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .search-wrapper {
        position: relative;
      }

      .search-input {
        padding: 8px 30px 8px 12px;
        border-radius: 6px;
        border: 1px solid #ccc;
        width: 220px;
      }

      .clear-btn {
        position: absolute;
        right: 8px;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        color: #888;
        font-weight: bold;
        display: none;
      }

      .clear-btn:hover {
        color: #000;
      }

      .search-select {
        padding: 8px;
        border-radius: 6px;
        border: 1px solid #ccc;
      }

      .search-btn {
        padding: 8px 14px;
        border-radius: 6px;
        border: 1px solid #28a745;
        background: transparent;
        color: #28a745;
        cursor: pointer;
      }

      .search-btn:hover {
        background: #28a745;
        color: white;
      }
    </style>
  </head>

  <body>

    <!-- NAVBAR -->
    <nav class="navbar">

      <!-- LEFT -->
      <div class="nav-left">
        <%= link_to "World Wide Recipes", menu_path, class: "brand" %>

        <div class="nav-links">
          <%= link_to "Menu", menu_path, class: (current_page?(menu_path) || controller_name == "recipes" ? "active" : "") %>
          <%= link_to "Categories", categories_path, class: (controller_name == "categories" ? "active" : "") %>
          <%= link_to "Areas", areas_path, class: (controller_name == "areas" ? "active" : "") %>
          <%= link_to "Ingredients", ingredients_path, class: (controller_name == "ingredients" ? "active" : "") %>
          <%= link_to "Tags", tags_path, class: (controller_name == "tags" ? "active" : "") %>

          <%= link_to "About", about_path, class: (current_page?(about_path) ? "active" : "") %>
          <%= link_to "Datasets", datasets_path, class: (current_page?(datasets_path) ? "active" : "") %>

        </div>
      </div>

      <!-- RIGHT (SEARCH) -->
      <form action="<%= menu_path %>" method="get" class="search-form">
        
        <div class="search-wrapper">
          <input 
            type="text" 
            name="query"
            placeholder="Recipe Search"
            value="<%= params[:query] %>"
            class="search-input"
            id="search-input"
          >

          <span class="clear-btn" id="clear-btn">×</span>
        </div>

        <select name="category" class="search-select">
          <option value="">All</option>
          <% Category.all.each do |c| %>
            <option value="<%= c.id %>" <%= "selected" if params[:category] == c.id.to_s %>>
              <%= c.name %>
            </option>
          <% end %>
        </select>

        <button type="submit" class="search-btn">Search</button>
      </form>

    </nav>

    <%= yield %>

   <script>
    // Search by typing key works and shows clear button when there's text, hides it when empty
    document.addEventListener("turbo:load", function () {
      const input = document.getElementById("search-input");
      const clearBtn = document.getElementById("clear-btn");

      if (!input || !clearBtn) return;

      if (input.dataset.initialized) return;
      input.dataset.initialized = "true";

      function toggleClear() {
        clearBtn.style.display = input.value.trim() ? "block" : "none";
      }

      clearBtn.addEventListener("click", function () {
        input.value = "";
        input.focus();
        toggleClear();

        // Submit form to reload full results
        input.form.submit();
      });

      input.addEventListener("input", toggleClear);

      toggleClear();
    });

    // Search by category select auto-submits form on change
    document.addEventListener("turbo:load", function () {
    const select = document.querySelector(".search-select");

    if (!select) return;

    select.addEventListener("change", function () {
      this.form.submit();
    });
  });
</script>   

  </body>
</html>

