  <!-- DATABASE STRUCTURE -->
  <div class="card mb-4 shadow-sm">
    <div class="card-body">
      <h4 class="mb-3">🗄️ Database Structure</h4>

      <ul>
        <li><strong>Recipes</strong></li>
        <li><strong>Categories</strong></li>
        <li><strong>Areas</strong></li>
        <li><strong>Ingredients</strong></li>
        <li><strong>Tags</strong></li>
      </ul>

      <p class="mt-3"><strong>Relationships:</strong></p>

      <ul class="mb-0">
        <li>A Recipe belongs to a Category and an Area</li>
        <li>A Recipe has many Ingredients</li>
        <li>An Ingredient could belong to many Recipes</li>
        <li>A Recipe has many Tags</li>
        <li>A Tag could belong to many Recipes</li>
      </ul>
    </div>
  </div>

