<div style="max-width: 1200px; margin: auto; font-family: Arial;">

  <h1 style="text-align: center;">🍽️ Menu</h1>

  <div style="
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    margin-top: 20px;
  ">

    <% @recipes.each do |recipe| %>
      <div style="
        border: 1px solid #ddd;
        border-radius: 12px;
        overflow: hidden;
        background: white;
        box-shadow: 0 2px 6px rgba(0,0,0,0.1);
      ">

        <img src="<%= recipe.img_url %>" 
             alt="<%= recipe.name %>" 
             style="width:100%; height:180px; object-fit:cover;">

        <div style="padding: 10px;">
          <h3 style="margin: 5px 0;"><%= recipe.name %></h3>

          <p style="margin: 0;">
            <strong>Category:</strong> <%= recipe.category&.name %>
          </p>

          <p style="margin: 0;">
            <strong>Area:</strong> <%= recipe.area&.name %>
          </p>
        </div>

      </div>
    <% end %>

  </div>

</div>