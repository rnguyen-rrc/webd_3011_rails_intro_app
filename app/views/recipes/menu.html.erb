<div class="container" style="max-width: 1100px;">

  <h1 class="text-center my-4">🍽️ Menu</h1>

  <div class="d-flex justify-content-center my-3">
    <%= paginate @recipes %>
  </div>

  <div class="row">

    <% if @recipes.any? %>
      <% @recipes.each do |recipe| %>

        <div class="col-sm-6 col-md-4 col-lg-3 mb-4">

          <%= link_to recipe_path(recipe), class: "text-decoration-none text-dark" do %>

            <div class="card h-100 shadow-sm">

              <img src="<%= recipe.img_url %>"
                   class="card-img-top"
                   style="height: 180px; object-fit: cover;"
                   alt="<%= recipe.name %>">

              <div class="card-body">
                <h2 class="card-title"><%= recipe.name %></h2>

                <p class="card-text">
                  <strong>Category:</strong> <%= recipe.category&.name %><br>
                  <strong>Area:</strong> <%= recipe.area&.name %>
                </p>
              </div>

            </div>

          <% end %>

        </div>

      <% end %>

    <% else %>

      <div class="col-12 text-center">
        <p>
          <% if params[:query].present? %>
            No recipes found for "<%= params[:query] %>". Try another search.
          <% elsif @selected_category %>
            No recipes found in the "<%= @selected_category.name %>" category.
          <% elsif params[:category].present? %>
            No recipes found for the selected category.
          <% else %>
            No recipes found.
          <% end %>
        </p>
      </div>

    <% end %>

  </div>

  <div class="d-flex justify-content-center my-3">
    <%= paginate @recipes %>
  </div>

</div>