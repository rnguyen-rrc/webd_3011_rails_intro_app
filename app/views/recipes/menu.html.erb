<div style="max-width: 1200px; margin: auto; font-family: Arial;">

  <h1 style="text-align: center;">🍽️ Menu</h1>

  <div class="pagination-container">
    <%= paginate @recipes %>
  </div>

  <div style="
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    margin-top: 20px;
  ">

    <% if @recipes.any? %>
        <% @recipes.each do |recipe| %>

            <%= link_to recipe_path(recipe), style: "text-decoration: none; color: inherit;" do %>

                <div style="
                border: 1px solid #ddd;
                border-radius: 12px;
                overflow: hidden;
                background: white;
                box-shadow: 0 2px 6px rgba(0,0,0,0.1);
                width: 280px;
                ">

                <img src="<%= recipe.img_url %>" 
                    alt="<%= recipe.name %>" 
                    style="width:100%; height:180px; object-fit:cover;">

                <div style="padding: 10px;">
                    <h2><%= recipe.name %></h2>

                    <p><strong>Category:</strong> <%= recipe.category&.name %></p>
                    <p><strong>Area:</strong> <%= recipe.area&.name %></p>
                </div>

                </div>

            <% end %>
        <% end %>
    <% else %>
        <p>
            <% if params[:query].present? %>
            No recipes found for "<%= params[:query] %>". Try another search.
            <% elsif params[:category].present? %>
            <% category = Category.find_by(id: params[:category]) %>
            <% if category %>
                No recipes found in the "<%= category.name %>" category.
            <% else %>
                No recipes found for the selected category.
            <% end %>
            <% else %>
            No recipes found.
            <% end %>
        </p>
    <% end %>
  </div>

  <div class="pagination-container">
    <%= paginate @recipes %>
  </div>
</div>