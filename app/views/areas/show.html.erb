<div class="container">
  <h1><%= @area.name %> Area</h1>

  <% if @area.latitude.present? && @area.longitude.present? %>
  <div style="margin-bottom: 24px;">
    <iframe
      width="100%"
      height="300"
      style="border:0; border-radius: 8px;"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      src="https://www.openstreetmap.org/export/embed.html?bbox=<%= @area.longitude - 5 %>,<%= @area.latitude - 5 %>,<%= @area.longitude + 5 %>,<%= @area.latitude + 5 %>&layer=mapnik&marker=<%= @area.latitude %>,<%= @area.longitude %>">
    </iframe>
  </div>
  <% end %>

  <h2>Recipes in Area:</h2>

  <table class="recipe-table">
    <thead>
      <tr>
        <th style="width: 100px;">Image</th>
        <th>Name</th>
      </tr>
    </thead>

    <tbody>
      <% @recipes.each do |recipe| %>
        <tr>
          <td>
            <% if recipe.img_url.present? %>
              <img src="<%= recipe.img_url %>" class="recipe-thumb">
            <% end %>
          </td>

          <td>
            <%= link_to recipe.name, recipe_path(recipe), class: "recipe-link" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <br>

  <%= link_to "← Back to Areas", areas_path %>
</div>